# ══════════════════════════════════════════════════════════════════
#  MADRS — Environment Configuration
#  Copy this file to .env and fill in the required values.
#  Never commit .env to git.
# ══════════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────────
DB_NAME=ai_ids
DB_USER=aisec
# REQUIRED: Change this password before deployment
DB_PASSWORD=changeme

# ── Security ───────────────────────────────────────────────────────
# REQUIRED: Generate with:  openssl rand -base64 64
JWT_SECRET=

# ── URLs (update with your server's IP or domain) ─────────────────
FRONTEND_URL=http://YOUR_SERVER_IP
API_BASE_URL=http://YOUR_SERVER_IP:8080
WS_BASE_URL=ws://YOUR_SERVER_IP:8080

# ── Email (for password reset and org welcome emails) ──────────────
# Use a Gmail App Password (not your main password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── Threat Intelligence (optional but recommended) ─────────────────
# Register free at https://www.abuseipdb.com/register
# Leave empty to use the built-in mock (scores random but functional)
ABUSEIPDB_KEY=
THREAT_INTEL_PROVIDER=auto

# ── Firewall Integration ───────────────────────────────────────────
# noop  = disable firewall enforcement (safe default for demo)
# auto  = use nftables if available (requires root/sudo on host)
FIREWALL_ENFORCER=noop

# ── Registration ───────────────────────────────────────────────────
# false = only the admin can create users (recommended for production)
ALLOW_SELF_REGISTER=false
