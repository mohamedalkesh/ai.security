# ===== ML Service =====
APP_NAME="AI Security ML Service"
HOST=127.0.0.1
PORT=8001
DEBUG=true

# CORS (Java Spring Boot will be the only client; allow it + dev frontend)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5500

# ===== Model =====
# Path to AI/model_artifacts (relative to ml-service/)
MODEL_ARTIFACTS_DIR=../AI/model_artifacts
# Path to AI/ folder (so we can import pcap_to_features.py)
AI_PACKAGE_DIR=../AI
CONFIDENCE_THRESHOLD=0.6

# ===== Storage =====
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_MB=1024

# ===== Performance =====
# 0 = auto (use CPU count). Increase if you want to parallelise NFStream parsing.
PCAP_WORKER_THREADS=0
